@model ICollection<BookHiveMVC.Models.Dto.GetBook>

<h2>List Book</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>PublishDate</th>
            <th>Author Name</th>
            <th>Category</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.Description</td>
                    <td>@book.PublishDate</td>
                    <td>@string.Join(", ",book.AuthorNames)</td>
                    <td>@string.Join(", ", book.CategoryNames)</td>
                    <td>
                        <ul>
                            <li>
                                <form asp-controller="Book" asp-action="Edit" asp-route-id="@book.Id" method="get">
                                    <button type="submit" class="btn btn-danger">Edit Book</button>
                                </form>
                            </li>
                            <li>
                                <form asp-controller="Book" asp-action="Delete" asp-route-id="@book.Id" method="post">
                                    <button type="submit" class="btn btn-danger">Delete Book</button>
                                </form>
                            </li>
                        </ul>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8">No Book available.</td>
            </tr>
        }
    </tbody>
</table>
<div>
    <a asp-controller="Book" asp-action="Create">Create Book</a>
</div>