@model ICollection<BookHiveMVC.Models.Dto.GetBook>

<h2>List Book</h2>

<form asp-controller="Book" asp-action="GetAllBookFromAuthor" method="get">
    <input type="hidden" name="authorId" value="@ViewBag.AuthorId" />
    <select name="categoryName" id="categoryFilter" class="form-control">
        <option value="">-- All Categories --</option>
        @foreach (var category in ViewBag.Categories)
        {
            <option value="@category.Name">@category.Name</option>
        }
    </select>
    <button type="submit" class="btn btn-primary">Filter</button>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>PublishDate</th>
            <th>Author Name</th>
            <th>Category</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.Description</td>
                    <td>@book.PublishDate</td>
                    <td>@string.Join(", ",book.AuthorNames)</td>
                    <td>@string.Join(", ", book.CategoryNames)</td>
                    <td>
                        <ul>
                            <li>
                                <form asp-controller="Book" asp-action="Edit" asp-route-id="@book.Id" method="get">
                                    <button type="submit" class="btn btn-danger">Edit Book</button>
                                </form>
                            </li>
                            <li>
                                <form asp-controller="Book" asp-action="Delete" asp-route-id="@book.Id" method="post">
                                    <button type="submit" class="btn btn-danger">Delete Book</button>
                                </form>
                            </li>
                        </ul>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8">No Book available.</td>
            </tr>
        }
    </tbody>
</table>

@{
    int totalPages = (int)Math.Ceiling((double)ViewBag.TotalItems / ViewBag.PageSize);
    int currentPage = ViewBag.Page;
}

<nav>
    <ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == currentPage ? "active" : "")">
                <a class="page-link"
                       asp-controller="Book"
                       asp-action="GetAllBookFromAuthor"
                       asp-route-authorId="@ViewBag.AuthorId"
                       asp-route-page="@i"
                       asp-route-pageSize="@ViewBag.PageSize">
                    @i
                </a>
            </li>
        }
    </ul>
</nav>

<div>
    <a asp-controller="Book" asp-action="Create">Create Book</a>
</div>